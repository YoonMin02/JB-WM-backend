# ─── Core ────────────────────────────────────────────────────────────
APP_ENV=local
APP_NAME=jb-wm-backend
API_HOST=127.0.0.1
API_PORT=8000
LOG_LEVEL=info

# ─── Database ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://jbwm:jbwm@localhost:5432/jbwm_dev

# ─── Auth ─────────────────────────────────────────────────────────────
JWT_SECRET=change-me

# ─── Codex / 추론 ─────────────────────────────────────────────────────
# 추론 백엔드: stub(기본, 무료·결정론적) / codex(실제 LLM, 쿼터 소모)
REASONER=stub
CODEX_MODEL=gpt-5.4
# 호출 한도 (쿼터 보호). 초과 시 API 429. 0=무제한
CODEX_MAX_CALLS_PER_MINUTE=30
CODEX_MAX_CALLS_TOTAL=500
# `codex login` OAuth 세션 사용 시 불필요. CLI 세션 없는 환경(CI 등)에서만 설정.
# OPENAI_API_KEY=sk-...
CODEX_WORKING_DIRECTORY=./workspace

# ─── Storage ──────────────────────────────────────────────────────────
FILE_STORAGE_DRIVER=local
LOCAL_STORAGE_PATH=./storage
POLICY_DOCS_PATH=./policy_docs
