# ─── Core ────────────────────────────────────────────────────────────
APP_ENV=local
APP_NAME=jb-wm-backend
API_HOST=127.0.0.1
API_PORT=8000
LOG_LEVEL=info

# ─── Database ─────────────────────────────────────────────────────────
DATABASE_URL=postgresql://jbwm:jbwm@localhost:5432/jbwm_dev

# ─── Auth ─────────────────────────────────────────────────────────────
JWT_SECRET=change-me
PRIVACY_SENSITIVE_RETENTION_DAYS=365

# ─── Reasoning / 추론 ─────────────────────────────────────────────────
# 추론 백엔드: stub(기본, 무료·결정론적) / pydantic_ai(PydanticAI + Codex SDK, 쿼터 소모)
REASONER=stub
CODEX_MODEL=gpt-5.4
CODEX_MODEL_REASONING_EFFORT=high
# 호출 한도 (쿼터 보호). 초과 시 API 429. 0=무제한
LLM_MAX_CALLS_PER_MINUTE=30
LLM_MAX_CALLS_TOTAL=500
# Codex SDK는 서버의 `codex login` OAuth 세션을 사용합니다.

# ─── Storage ──────────────────────────────────────────────────────────
FILE_STORAGE_DRIVER=local
LOCAL_STORAGE_PATH=./storage
POLICY_DOCS_PATH=./policy_docs

# ─── Action execution ─────────────────────────────────────────────────
# mock_apply: 승인 결과를 mock DB에 반영합니다. 예: 심혈관 특약 점검 완료, 포트폴리오 mock 리밸런싱.
# external_request: 실제 외부 실행 요청 모드입니다. 현재는 안전상 막혀 있으며 Executor 구현 후 사용합니다.
ACTION_EXECUTION_MODE=mock_apply
