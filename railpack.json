{
  "$schema": "https://schema.railpack.com",
  "provider": "python",
  "packages": {
    "python": "3.12",
    "node": "22"
  },
  "steps": {
    "install": {
      "commands": [
        "...",
        "npm install -g @openai/codex@0.135.0"
      ]
    }
  },
  "deploy": {
    "startCommand": "uv run uvicorn app.main:app --host 0.0.0.0 --port $PORT"
  }
}
